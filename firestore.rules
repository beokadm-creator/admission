rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isMaster() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        adminDoc().data.role == 'MASTER';
    }

    function isAdminOfSchool(schoolId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        (
          adminDoc().data.role == 'MASTER' ||
          adminDoc().data.assignedSchoolId == schoolId
        );
    }

    match /admins/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create, update, delete: if isMaster();
    }

    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isAdminOfSchool(schoolId);

      match /stats/{document=**} {
        allow read: if isAdminOfSchool(schoolId);
        allow write: if false;
      }

      match /registrations/{regId} {
        allow read, delete: if isAdminOfSchool(schoolId);
        allow create, update: if false;
      }

      match /queueState/{docId} {
        allow read: if true;
        allow write: if false;
      }

      match /queueEntries/{userId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if false;
      }

      match /reservations/{reservationId} {
        allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow write: if false;
      }

      match /requestLocks/{requestId} {
        allow read, write: if false;
      }

      match /privateSettings/{docId} {
        allow read, write: if isAdminOfSchool(schoolId);
      }
    }

    match /counters/{schoolId} {
      allow read, write: if false;
    }

    match /rateLimits/{document} {
      allow read, write: if false;
    }

    match /alimtalkQueue/{document} {
      allow read, write: if false;
    }

    match /capacityAlerts/{document} {
      allow read: if isMaster();
      allow write: if false;
    }
  }
}
