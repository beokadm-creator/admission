{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  },
  "emulators": {
    "ui": {
      "enabled": true,
      "port": 14005
    },
    "hub": {
      "port": 14405
    },
    "logging": {
      "port": 14505
    },
    "firestore": {
      "host": "127.0.0.1",
      "port": 18085
    },
    "database": {
      "host": "127.0.0.1",
      "port": 19005
    },
    "auth": {
      "host": "127.0.0.1",
      "port": 9099
    },
    "pubsub": {
      "host": "127.0.0.1",
      "port": 18086
    },
    "functions": {
      "host": "127.0.0.1",
      "port": 15005
    }
  }
}
